# Azure Speech Service credentials (used by MAI-Transcribe-1 and MAI-Voice-1)
# Create a Speech resource in the Azure portal and copy the key and region.
AZURE_SPEECH_KEY=your_speech_resource_key_here
AZURE_SPEECH_REGION=eastus

# Azure AI Foundry credentials (used by MAI-Image-2)
# You can use either the Foundry resource endpoint or a project endpoint.
# Set AZURE_FOUNDRY_AUTH_METHOD=azuredefault to use DefaultAzureCredential.
# Set AZURE_TENANT_ID when the resource belongs to a specific tenant.
# The app normalizes project endpoints like
# https://your-resource.services.ai.azure.com/api/projects/proj-default
# to the resource base URL required by the MAI image API.
AZURE_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/proj-default
AZURE_FOUNDRY_AUTH_METHOD=azuredefault
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_DEPLOYMENT=mai-image-2
