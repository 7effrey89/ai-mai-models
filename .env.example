# Azure Speech Service credentials (used by MAI-Transcribe-1 and MAI-Voice-1)
# Create a Speech resource in the Azure portal and copy the key and region.
AZURE_SPEECH_KEY=your_speech_resource_key_here
AZURE_SPEECH_REGION=eastus

# Azure OpenAI / Foundry credentials (used by MAI-Image-2)
# Deploy MAI-Image-2 in Microsoft Foundry and copy the resource name,
# deployment name, API key and API version from the portal.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_KEY=your_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=mai-image-2
AZURE_OPENAI_API_VERSION=2024-02-15-preview
